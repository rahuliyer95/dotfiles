{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": false,
  "lsp": false,
  "plugin" : [
    "@mohak34/opencode-notifier@v0.2.4",
    "@franlol/opencode-md-table-formatter@v0.0.6"
  ],
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "* > *": "ask",
      "* >> *": "ask",
      "dd *": "ask",
      "gh api *": "ask",
      "gh pr create *": "ask",
      "git checkout *": "ask",
      "git push *": "ask",
      "rm *": "ask",
      "sed *": "ask"
    },
    "edit": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "share": "disabled"
}
