{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": false,
  "lsp": false,
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "* > *": "ask",
      "* >> *": "ask",
      "dd *": "ask",
      "gh api *": "ask",
      "gh pr create *": "ask",
      "git checkout *": "ask",
      "git push *": "ask",
      "rm *": "ask",
      "sed *": "ask"
    },
    "edit": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "share": "disabled"
}
